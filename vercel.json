{
  "framework": "nextjs",
  "headers": [
    {
      "source": "/admin/(.*)",
      "headers": [
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/email-reminder",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron/npc-schedule",
      "schedule": "0 3 * * *"
    }
  ]
}